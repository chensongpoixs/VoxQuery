# ============================================================
# 知识库问答系统 - 环境变量配置模板
# ============================================================
# 此文件只需设置部署模式和硬件配置，
# 运行 'make config' 将从 profile 自动生成完整的 .env 文件。
# ============================================================

# ---------- 部署配置 ----------
# 部署模式: docker | native
# DEPLOYMENT_MODE=docker

# # 硬件配置: single-gpu | multi-gpu
# HARDWARE_PROFILE=multi-gpu

# # ---------- 模型存储 ----------
# # 所有模型文件的本地缓存目录
# MODELS_DIR=./models
# ============================================================
# 知识库问答系统 - 环境变量配置
# Profile: multi-gpu (4×RTX 4090 (24GB×4) 分布式部署，适合生产环境)
# 部署模式: docker
# GPU: 4×NVIDIA RTX 4090
# 自动生成，请勿手动编辑
# ============================================================

# ---------- 全局配置 ----------
PROJECT_NAME=kb-qa
DEPLOYMENT_MODE=docker
HARDWARE_PROFILE=multi-gpu
MODELS_DIR=./models
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- API Gateway ----------
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CONVERSATION_TTL=86400
RETRIEVAL_CACHE_TTL=3600

# ---------- LLM 服务 ----------
LLM_MODEL_NAME=google/gemma-3-27b-it
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_CONTEXT_WINDOW=8192
LLM_TENSOR_PARALLEL_SIZE=2
LLM_QUANTIZATION=awq
LLM_MAX_CONCURRENT=4
LLM_GPU_MEMORY_UTILIZATION=0.9
LLM_KV_CACHE_DTYPE=fp8
NVIDIA_VISIBLE_DEVICES_LLM=0,1

# ---------- Embedding 服务 ----------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_BATCH_SIZE=32
NVIDIA_VISIBLE_DEVICES_EMBEDDING=2

# ---------- RAG 服务 ----------
RAG_TOP_K=5
RAG_RERANK_TOP_N=3
RAG_SIMILARITY_THRESHOLD=0.65

# ---------- ChromaDB ----------
CHROMA_HOST=chromadb
CHROMA_PORT=8004
CHROMA_COLLECTION_NAME=kb_knowledge

# ---------- ASR 服务 ----------
ASR_MODEL_NAME=large-v3
ASR_LANGUAGE=zh
ASR_VAD_THRESHOLD=0.5

# ---------- TTS 服务 ----------
TTS_DEFAULT_VOICE=default
TTS_SAMPLE_RATE=24000
NVIDIA_VISIBLE_DEVICES_ASR_TTS=3

# ---------- GPU 分配 ----------
NVIDIA_VISIBLE_DEVICES_LLM=0,1
NVIDIA_VISIBLE_DEVICES_EMBEDDING=2
NVIDIA_VISIBLE_DEVICES_ASR_TTS=3

# ---------- 模型下载 ----------
HF_ENDPOINT=https://hf-mirror.com
USE_MODELSCOPE=true

# ---------- 知识库 ----------
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=50
