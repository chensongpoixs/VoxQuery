# ============================================================
# 知识库问答系统 - 环境变量配置模板
# 复制此文件为 .env 并修改相应配置
# ============================================================

# ---------- 全局配置 ----------
PROJECT_NAME=kb-qa
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---------- API Gateway ----------
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4

# JWT 鉴权
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440           # 24 小时

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 对话历史 TTL (秒)
CONVERSATION_TTL=86400            # 24 小时
# 检索缓存 TTL (秒)
RETRIEVAL_CACHE_TTL=3600          # 1 小时

# ---------- LLM 服务 (Gemma-3 27B + vLLM) ----------
LLM_SERVICE_HOST=llm-service
LLM_SERVICE_PORT=8001
LLM_MODEL_NAME=google/gemma-3-27b-it
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_CONTEXT_WINDOW=8192           # RTX 4090 显存限制
LLM_TENSOR_PARALLEL_SIZE=2        # 2×GPU 张量并行
LLM_QUANTIZATION=awq              # INT8 量化方式
LLM_MAX_CONCURRENT=4              # 最大并发推理数

# ---------- Embedding 服务 (BGE-M3) ----------
EMBEDDING_SERVICE_HOST=embedding-service
EMBEDDING_SERVICE_PORT=8002
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_BATCH_SIZE=32

# ---------- RAG 服务 ----------
RAG_SERVICE_HOST=rag-service
RAG_SERVICE_PORT=8003
RAG_TOP_K=5                       # 初始召回数量
RAG_RERANK_TOP_N=3                # 重排序后保留数量
RAG_SIMILARITY_THRESHOLD=0.65     # 相似度阈值

# ---------- ChromaDB ----------
CHROMA_HOST=chromadb
CHROMA_PORT=8004
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=kb_knowledge

# ---------- ASR 服务 (Whisper-large-v3) ----------
ASR_SERVICE_HOST=asr-service
ASR_SERVICE_PORT=8005
ASR_MODEL_NAME=large-v3
ASR_LANGUAGE=zh                   # 默认中文，支持 auto 自动检测
ASR_VAD_THRESHOLD=0.5             # 语音活动检测阈值

# ---------- TTS 服务 (CosyVoice2) ----------
TTS_SERVICE_HOST=tts-service
TTS_SERVICE_PORT=8006
TTS_DEFAULT_VOICE=default         # 默认音色
TTS_SAMPLE_RATE=24000

# ---------- GPU 分配 ----------
# GPU_0,1 -> LLM (Gemma-3)
# GPU_2   -> Embedding (BGE-M3)
# GPU_3   -> ASR + TTS (共享)
NVIDIA_VISIBLE_DEVICES_LLM=0,1
NVIDIA_VISIBLE_DEVICES_EMBEDDING=2
NVIDIA_VISIBLE_DEVICES_ASR_TTS=3

# ---------- 模型下载镜像（国内环境使用） ----------
# HuggingFace 镜像: https://hf-mirror.com
# ModelScope 镜像: https://modelscope.cn
HF_ENDPOINT=https://hf-mirror.com
# 是否优先使用 ModelScope 下载（国内速度更快）
USE_MODELSCOPE=true
# ModelScope 模型 ID 映射
MODELSCOPE_GEMMA3=iic/gemma-3-27b-it
MODELSCOPE_BGE_M3=BAAI/bge-m3
MODELSCOPE_WHISPER=iic/whisper-large-v3

# ---------- 模型存储路径 ----------
MODELS_DIR=./models               # 模型文件本地缓存目录

# ---------- 知识库 ----------
KNOWLEDGE_DOCS_DIR=./knowledge-base/sample-docs
KNOWLEDGE_CHUNK_SIZE=512          # 文档分块大小 (tokens)
KNOWLEDGE_CHUNK_OVERLAP=50        # 分块重叠大小 (tokens)
