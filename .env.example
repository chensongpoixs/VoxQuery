# ============================================================
# 知识库问答系统 - 环境变量配置模板
# ============================================================
# 此文件只需设置部署模式和硬件配置，
# 运行 'make config' 将从 profile 自动生成完整的 .env 文件。
# ============================================================

# ---------- 部署配置 ----------
# 部署模式: docker | native
DEPLOYMENT_MODE=docker

# 硬件配置: single-gpu | multi-gpu
HARDWARE_PROFILE=multi-gpu

# ---------- 模型存储 ----------
# 所有模型文件的本地缓存目录
MODELS_DIR=./models
